# このファイルをコピーして「.env」という名前で保存し、実際の値を入れてください。
# .env は秘密情報（APIキーなど）が入るので、絶対にGitHubなどに公開しないこと！

# LINE Developers コンソールの「Messaging API設定」タブで確認できます
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# OpenAIのAPIキー（https://platform.openai.com/api-keys で発行）
OPENAI_API_KEY=your_openai_api_key_here

# 以下は変更しなくてOK（初心者向けのデフォルト値）
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3
DAILY_LIMIT=3
USAGE_FILE_PATH=data/usage.json
